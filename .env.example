# ============================================
# Tiffy Social - Environment Variables
# ============================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
# In production on Vercel, this is set automatically via VERCEL_PROJECT_PRODUCTION_URL
NEXTAUTH_URL="http://localhost:3000"

# --- File Storage (Vercel Blob) ---
# Required for production. Get from Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Email (Resend) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Optional: custom sender (requires verified domain on Resend)
# FROM_EMAIL="Tiffy Social <noreply@seudominio.com>"

# --- Payments: MercadoPago ---
# Get from https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_PUBLIC_KEY="APP_USR-..."

# --- Payments: NowPayments (Crypto) ---
# Get from https://nowpayments.io
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_PUBLIC_KEY=""
NOWPAYMENTS_IPN_SECRET=""
